{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "https://athar-api-production.up.railway.app/sitemap.xml" },
    { "source": "/robots.txt", "destination": "https://athar-api-production.up.railway.app/robots.txt" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
